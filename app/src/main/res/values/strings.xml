    <string name="onboarding_welcome_title">Welcome to DocuFind</string>
    <string name="onboarding_welcome_subtitle">Add IDs, medical papers, insurance, vehicle docs and family records in one private vault on your phone.</string>
    <string name="onboarding_store_title">Everything Important, One Secure Place</string>
    <string name="onboarding_store_subtitle">Store ID cards, medical records, insurance papers, vehicle documents, education records, pet details and more.</string>
    <string name="onboarding_search_title">Find fast. Never miss a date.</string>
    <string name="onboarding_search_subtitle">Search in seconds and get reminders before expiry, renewals, vaccinations and warranty dates.</string>
    <string name="onboarding_secure_title">Your data stays on your phone</string>
    <string name="onboarding_secure_subtitle">Files are encrypted on-device with AES-256 (NIST-aligned), like WhatsApp\'s end-to-end idea — DocuFind cannot read your vault. Unlock with PIN or biometrics.</string>
    <string name="security_encryption_title">How DocuFind protects your data</string>
    <string name="security_encryption_body">Vault files and sensitive fields use AES-256-GCM with keys in Android Keystore (NIST-aligned crypto). Data stays on your device — DocuFind has no cloud copy of your documents. This is the same privacy model people trust in WhatsApp-style end-to-end encryption: only you unlock the content. We do not claim government FIPS certification.</string>
